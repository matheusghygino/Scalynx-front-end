---
import { Image } from "astro:assets";

import growth from "../assets/Index/hero_section_1.png";
import analytics from "../assets/Index/hero_section_2.png";
---

<section
  class="pt-20 md:py-24 bg-gradient-to-r from-primary to-secondary text-white overflow-hidden"
>
  <div
    class="max-w-6xl px-6 grid md:grid-cols-2 gap-8 items-center pt-8 mx-auto"
  >
    <!-- Texto -->
    <div>
      <h1 class="text-4xl md:text-5xl font-title font-bold mb-4">
        Seu marketing, sua operação e sua tecnologia conectados em um único
        sistema.
      </h1>

      <p class="text-lg md:text-xl font-body mb-8">
        A Scalyns constrói ecossistemas digitais completos: site de alta
        performance, CRM personalizado, automações inteligentes, tráfego pago,
        gestão de redes sociais e identidade visual estratégica — tudo integrado
        para gerar crescimento previsível.
      </p>

      <a
        href="#contato"
        class="inline-block bg-white text-primary font-semibold px-6 py-3 rounded-full hover:bg-gray-100 transition"
      >
        Construir meu ecossistema digital
      </a>
    </div>

    <!-- Imagens -->
    <div
      class="relative w-full h-auto hidden md:flex justify-center items-center"
      aria-hidden="true"
    >
      <!-- Imagem maior -->
      <Image
        src={analytics}
        alt="Dashboard de analytics"
        width={450}
        format="avif"
        quality={80}
        loading="eager"
        fetchpriority="high"
        class="rounded-xl w-[400px] lg:w-[450px] h-auto"
      />

      <!-- Imagem menor -->
      <Image
        src={growth}
        alt="Dashboard de growth"
        width={350}
        format="avif"
        quality={80}
        class="absolute top-5/10 lg:right-3 lg:translate-x-1/3 -translate-y-1/3 w-[350px] rounded-xl"
        loading="lazy"
      />
    </div>
  </div>
</section>
