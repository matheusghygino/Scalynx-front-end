---
/* File: src/components/ContactFormBR.astro */
const { id = "ContactFormBR", source = "" } = Astro.props;

// ========= Config =========
const WORKER_URL = "https://lead-gateway.matheus-hygino.workers.dev";
const TURNSTILE_SITE_KEY = "0x4AAAAAACBtETYrmppk61_g";
const FORM_ID = "site-2";
---

<form
  id={id}
  data-contact-form
  data-worker-url={WORKER_URL}
  method="POST"
  class="space-y-6 text-black"
  novalidate
>
  <!-- Identificador usado pelo Worker para escolher o webhook do n8n -->
  <input type="hidden" name="form_id" value={FORM_ID} />

  <!-- Honeypot -->
  <div class="hidden">
    <label for="website">Website</label>
    <input type="text" id="website" name="company_website" />
  </div>

  <!-- Timestamp anti-bot -->
  <input type="hidden" name="ts_loaded" value={Date.now().toString()} />

  <!-- Data e hora de envio -->
  <input type="hidden" id="submittedAt" name="submittedAt" />

  <!-- Origem do formulário -->
  <input type="hidden" name="formSource" value={source} />

  <!-- Dados de contato -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <input
      type="text"
      id="firstName"
      name="firstName"
      placeholder="Nome"
      required
      class="w-full border border-gray-300 rounded-md px-4 py-2 placeholder-gray-500"
      autocomplete="given-name"
    />

    <input
      type="text"
      id="lastName"
      name="lastName"
      placeholder="Sobrenome"
      required
      class="w-full border border-gray-300 rounded-md px-4 py-2 placeholder-gray-500"
      autocomplete="family-name"
    />

    <input
      type="email"
      id="email"
      name="email"
      placeholder="E-mail"
      required
      class="w-full border border-gray-300 rounded-md px-4 py-2 md:col-span-2 placeholder-gray-500"
      autocomplete="email"
    />

    <input
      type="tel"
      id="phone"
      name="phone"
      placeholder="Telefone (com DDD)"
      required
      class="w-full border border-gray-300 rounded-md px-4 py-2 md:col-span-2 placeholder-gray-500"
      inputmode="tel"
      autocomplete="tel"
    />
  </div>

  <input
    type="text"
    id="subject"
    name="subject"
    placeholder="Assunto"
    required
    class="w-full border border-gray-300 rounded-md px-4 py-2 placeholder-gray-500"
  />

  <textarea
    id="message"
    name="message"
    rows="4"
    placeholder="Descreva sua necessidade (opcional)"
    class="w-full border border-gray-300 rounded-md px-4 py-2 placeholder-gray-500"
  ></textarea>

  <!-- Consentimento -->
  <div class="mb-4">
    <label class="flex items-center">
      <input
        type="checkbox"
        id="consent"
        name="consent"
        required
        class="form-checkbox h-4 w-4 text-primary rounded placeholder-gray-500"
      />
      <span class="ml-2 text-gray-700 text-sm">
        Concordo em receber contato por e-mail ou WhatsApp.
      </span>
    </label>
  </div>

  <!-- Turnstile -->
  <div class="flex justify-center">
    <div
      class="cf-turnstile"
      data-sitekey={TURNSTILE_SITE_KEY}
      data-theme="light"
      data-size="normal"
    ></div>
  </div>

  <!-- Enviar -->
  <button
    type="submit"
    class="w-full bg-primary text-white font-semibold py-3 px-6 rounded-md hover:bg-dark transition"
    data-submit-button
  >
    Enviar solicitação
  </button>

  <p id="result" class="text-center text-sm text-gray-500 mt-4"></p>
</form>

<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

<script define:vars={{ id }}>
  function validarTelefoneBR(valor) {
    const digits = (valor || "").replace(/\D/g, "");

    if (digits.length === 10) {
      const ddd = digits.slice(0, 2);
      const numero = digits.slice(2);
      return /^[1-9]\d$/.test(ddd) && /^\d{8}$/.test(numero);
    }

    if (digits.length === 11) {
      const ddd = digits.slice(0, 2);
      const numero = digits.slice(2);
      return /^[1-9]\d$/.test(ddd) && /^9\d{8}$/.test(numero);
    }

    if (digits.startsWith("55")) {
      return validarTelefoneBR(digits.slice(2));
    }

    return false;
  }

  function validateFields(form) {
    const honeypot = form.querySelector('input[name="company_website"]')?.value || "";
    if (honeypot) return false;

    const ts = parseInt(form.querySelector('input[name="ts_loaded"]')?.value || "0", 10);

    if (Date.now() - ts < 2000) {
      alert("Envio muito rápido. Preencha o formulário normalmente e tente novamente.");
      return false;
    }

    const phoneInput = form.querySelector('input[name="phone"]');

    if (!validarTelefoneBR(phoneInput.value)) {
      alert("Telefone inválido. Use DDD e, se celular, inclua o 9.");
      phoneInput.focus();
      return false;
    }

    const consent = form.querySelector('input[name="consent"]');

    if (!consent?.checked) {
      alert("Você precisa aceitar o contato por e-mail ou WhatsApp.");
      return false;
    }

    if (!form.checkValidity()) {
      form.reportValidity();
      return false;
    }

    return true;
  }

  document.addEventListener("DOMContentLoaded", () => {
    const form = document.getElementById(id);
    const result = document.getElementById("result");
    const submitButton = form?.querySelector("[data-submit-button]");

    if (!form || !result || !submitButton) return;

    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      if (!validateFields(form)) return;

      const workerUrl = form.dataset.workerUrl;

      if (!workerUrl) {
        result.textContent = "Erro de configuração: Worker ausente.";
        result.className = "text-center text-sm text-red-500 mt-4";
        return;
      }

      const formData = new FormData(form);
      const turnstileToken = formData.get("cf-turnstile-response");

      if (!turnstileToken) {
        result.textContent = "Confirme a verificação de segurança antes de enviar.";
        result.className = "text-center text-sm text-red-500 mt-4";
        return;
      }

      document.getElementById("submittedAt").value = new Date().toISOString();

      submitButton.disabled = true;
      submitButton.textContent = "Enviando...";

      result.style.display = "block";
      result.textContent = "Enviando...";
      result.className = "text-center text-sm text-gray-500 mt-4";

      try {
        const res = await fetch(workerUrl, {
          method: "POST",
          body: formData,
        });

        const responseData = await res.json().catch(() => ({}));

        if (!res.ok || !responseData.success) {
          throw new Error(responseData.message || `HTTP ${res.status}`);
        }

        window.dataLayer = window.dataLayer || [];

        const emailVal = form.querySelector('#email')?.value?.trim() || "";
        const firstNameVal = form.querySelector('#firstName')?.value?.trim() || "";
        const lastNameVal = form.querySelector('#lastName')?.value?.trim() || "";
        const formNameVal = "Contato – Site BR";
        const formIdVal = form.getAttribute('id') || "ContactFormBR";
        const sourceVal = form.querySelector('input[name="formSource"]')?.value || "";

        if (emailVal) {
          window.dataLayer.push({
            event: "user_identified",
            user_email: emailVal,
            user_first_name: firstNameVal,
            user_last_name: lastNameVal
          });
        }

        window.dataLayer.push({
          event: "form_submit",
          form_id: formIdVal,
          form_name: formNameVal,
          form_source: sourceVal
        });

        result.textContent = "Formulário enviado com sucesso!";
        result.className = "text-center text-sm text-green-500 mt-4";

        form.reset();

        if (window.turnstile) {
          window.turnstile.reset();
        }

        window.location.href = "/thanks";
      } catch (error) {
        result.textContent = "Erro ao enviar: " + (error?.message || "desconhecido");
        result.className = "text-center text-sm text-red-500 mt-4";
      } finally {
        submitButton.disabled = false;
        submitButton.textContent = "Enviar solicitação";
      }
    });
  });
</script>